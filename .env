# Path to store OpenList configuration and data on the host
CONFIG_PATH=/etc/openlist

# Port for HTTP access (mapped to container port 5244)
OPENLIST_PORT=5244

# Port for HTTPS access (mapped to container port 5245)
OPENLIST_PORT_SSL=5245

# User ID under which the container will run (0 = root)
OPENLIST_UID=0

# Group ID under which the container will run (0 = root)
OPENLIST_GID=0

# Umask setting for file permissions inside the container
OPENLIST_UMASK=022

# Timezone setting for the container
TZ=UTC